# Windows system files
desktop.ini
Thumbs.db

# Python
__pycache__/
*.pyc
*.pyo
*.pyd
.ipynb_checkpoints
.venv/
venv/
env/

# Data & Models (Tránh đẩy tệp dung lượng lớn lên GitHub)
# Bỏ qua toàn bộ nội dung trong các thư mục con của data nhưng giữ tệp .gitkeep
data/home-credit-default-risk/*
data/processed/*
data/raw/*
data/sample/*

# Bỏ qua toàn bộ nội dung trong các thư mục con của data nhưng giữ tệp .gitkeep
!data/sample/.gitkeep
!data/processed/.gitkeep
!data/raw/.gitkeep

# Bỏ qua toàn bộ nội dung trong models ngoại trừ tệp .gitkeep
models/*
!models/.gitkeep
# Ngoại lệ: model_metadata.json (~10KB) mô tả thứ tự 297 cột đầu vào của model.
# App Streamlit và NB07 cần đúng thứ tự này mới dự đoán ra kết quả đúng; thiếu nó
# thì phải chạy lại NB06 (~5 phút + cần train_features.csv 1,87GB) chỉ để lấy 10KB.
# File nhỏ nên không trái lý do "tránh đẩy tệp dung lượng lớn" ở trên.
# (Nhóm trưởng Hưng đã đồng ý cho ngoại lệ này — T11.)
!models/model_metadata.json

# Jupyter Notebook checkpoints
.ipynb_checkpoints/
*/.ipynb_checkpoints/

# OMC (oh-my-claudecode) - trạng thái công cụ, không commit
.omc/

# Khai bao ten thanh vien (moi may 1 lan) - rieng tung may, khong commit
.claude/whoami

# Task Tracker - nhom truong quan ly rieng ben ngoai repo, khong commit
Task_Tracker.xlsx

# File cau hinh bien moi truong local - rieng tung may, khong commit
.env
